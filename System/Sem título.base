views:
  - type: table
    name: Tabela
    filters:
      and:
        - file.inFolder("Estudos/UTFPR - Eng. de Software")
        - Tipo == "Disciplina"
    groupBy:
      property: Atividades
      direction: ASC
    order:
      - file.name
      - Anotações
      - Atividades
      - Avaliações
    sort:
      - property: Atividades
        direction: ASC
    summaries:
      Status: Unique
  - type: list
    name: Visualizaçao padrão
