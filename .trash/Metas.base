views:
  - type: cards
    name: Tabela
    filters:
      and:
        - file.inFolder("Metas")
        - '!file.hasProperty("Conclusão")'
        - "!Concluida"
    order:
      - file.name
      - Prioridade
      - Concluida
      - Data Limite
    sort:
      - property: Prioridade
        direction: ASC
  - type: table
    name: Visualizaçao padrão
    filters:
      and:
        - file.inFolder("Metas")
    rowHeight: medium
